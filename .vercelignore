# Backend completo - este deploy es frontend-only en Vercel.
# Vercel autodetecta /api/*.ts como Serverless Functions; excluimos
# todo el backend Hono heredado (que no está adaptado a serverless),
# pero PERMITIMOS las nuevas Vercel Edge Functions (api/registro.ts).
#
# Cómo funciona la sintaxis: las líneas que empiezan con "!" niegan
# una exclusión anterior. Por eso primero excluimos todo api/ y luego
# negamos los archivos concretos que SÍ queremos desplegar.
api/
!api/registro.ts

db/
contracts/

# Configs solo de backend (que no son referenciadas desde tsconfig.json root)
Dockerfile
.dockerignore
.backend-features.json

# IMPORTANTE: NO excluir tsconfig.server.json ni drizzle.config.ts.
# tsconfig.json (root) los referencia via "references" y Vite los necesita
# para resolver correctamente al procesar index.html.

# Tests y dev
__tests__/
*.test.ts
vitest.config.ts

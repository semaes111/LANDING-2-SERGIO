# Backend completo - este deploy es frontend-only en Vercel.
# Vercel autodetecta /api/*.ts como Serverless Functions; excluimos
# los archivos del backend Hono heredado (que no está adaptado a
# serverless), pero PERMITIMOS las nuevas Vercel Edge Functions.
#
# IMPORTANTE: gitignore NO permite re-incluir archivos cuando el
# directorio padre está excluido por nombre. Por eso aquí enumeramos
# archivos individuales del backend en lugar de excluir todo api/.
api/auth-router.ts
api/boot.ts
api/consultation-router.ts
api/context.ts
api/middleware.ts
api/reservation-router.ts
api/router.ts
api/lib/
api/queries/
api/kimi/

db/
contracts/

# Configs solo de backend (que no son referenciadas desde tsconfig.json root)
Dockerfile
.dockerignore
.backend-features.json

# IMPORTANTE: NO excluir tsconfig.server.json ni drizzle.config.ts.
# tsconfig.json (root) los referencia via "references" y Vite los necesita
# para resolver correctamente al procesar index.html.

# Tests y dev
__tests__/
*.test.ts
vitest.config.ts

# Backend completo - este deploy es frontend-only en Vercel.
# Vercel autodetecta /api/*.ts como Serverless Functions; lo excluimos
# porque el backend Hono no está adaptado a serverless (ver vercel.json).
api/
db/
contracts/

# Configs solo de backend (que no son referenciadas desde tsconfig.json root)
Dockerfile
.dockerignore
.backend-features.json

# IMPORTANTE: NO excluir tsconfig.server.json ni drizzle.config.ts.
# tsconfig.json (root) los referencia via "references" y Vite los necesita
# para resolver correctamente al procesar index.html.

# Tests y dev
__tests__/
*.test.ts
vitest.config.ts
